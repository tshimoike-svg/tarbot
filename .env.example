# J-Quants API v2 認証（このファイルをコピーして .env を作る。 .env は git 管理外）
#   cp .env.example .env  して値を埋める
# J-Quants ダッシュボードで発行した APIキーを設定する（x-api-key ヘッダに使われる）。
JQUANTS_API_KEY=

# 発注フラグ（既定はドライラン。本番発注は人間が明示的に解除する）
# DRY_RUN=false

# kabuステーションAPI 認証（kabuステーションのAPI設定画面で登録したパスワード）
# 本番/検証は scripts/kabu_ping.py の --env で切り替える（パスワードは共通）。
# kabuステーションが起動・ログイン中でないとAPIは応答しない。
KABU_API_PASSWORD=
