# J-Quants API v2 認証（このファイルをコピーして .env を作る。 .env は git 管理外）
#   cp .env.example .env  して値を埋める
# J-Quants ダッシュボードで発行した APIキーを設定する（x-api-key ヘッダに使われる）。
JQUANTS_API_KEY=

# 発注フラグ（既定はドライラン。本番発注は人間が明示的に解除する）
# DRY_RUN=false

# kabuステーションAPI 認証（システム設定「APIタブ」で本番用・検証用を別々に登録する）
# kabuステーションが起動・ログイン中でないとAPIは応答しない。
KABU_API_PASSWORD_PROD=
KABU_API_PASSWORD_DEMO=

# kabuステーションAPI 発注用「取引パスワード」（上記APIパスワードとは別。注文設定で登録）
# order_engine.py の send_order でのみ使う。DRY_RUN=True の間は参照されない。
KABU_ORDER_PASSWORD_PROD=
KABU_ORDER_PASSWORD_DEMO=
